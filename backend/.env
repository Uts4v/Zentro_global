# ── Django Core ───────────────────────────────────────────────────────────────
# IMPORTANT: Change SECRET_KEY to a long random string before going to production.
SECRET_KEY=django-insecure-dev-key-CHANGE-THIS-before-production-use-openssl-rand
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,zentro-global.onrender.com

# ── Database ───────────────────────────────────────────────────────────────────
# Default: SQLite (dev). To switch to PostgreSQL, set DB_ENGINE and the DB_* vars.
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=zentro
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=5432
# DB_SSLMODE=prefer

# ── JWT ────────────────────────────────────────────────────────────────────────
# No extra config needed — simplejwt uses SECRET_KEY above.

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://localhost:8082,https://zentro-frontend.onrender.com

# ── Email ──────────────────────────────────────────────────────────────────────
# Development: uses console backend (prints to terminal). Set these for production:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=your_app_password
# DEFAULT_FROM_EMAIL=Zentro <noreply@zentro.app>

# ── Frontend URL (for password reset emails) ───────────────────────────────────
FRONTEND_URL=http://localhost:5173
# Production: FRONTEND_URL=https://zentro-frontend.onrender.com
